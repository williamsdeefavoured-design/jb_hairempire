# Copy this file to .env and fill in your secrets. DO NOT commit your .env file.

# Copy your Google AI Studio key here (do NOT commit):
# GOOGLE_AI_KEY=your_google_ai_key_here

# Backwards compatibility: if other tooling expects `LOVABLE_API_KEY`, you
# can set it to the same value as `GOOGLE_AI_KEY`.
# LOVABLE_API_KEY=your_google_ai_key_here
